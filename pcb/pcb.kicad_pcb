			(back yes)
		)
		(covering
			(front no)
			(back no)
		)
		(plugging
			(front no)
			(back no)
		)
		(capping no)
		(filling no)
		(zone_defaults)
		(aux_axis_origin 100 150)
		(pcbplotparams
